{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "memory-stability-correction-event.schema.json",
  "title": "Memory Stability Correction Execution Event",
  "type": "object",
  "required": [
    "schema_version",
    "event_type",
    "event_id",
    "created_at",
    "session_id",
    "provider",
    "model_name",
    "source_snapshot",
    "execution",
    "audit"
  ],
  "properties": {
    "schema_version": {
      "const": "memory-stability-correction-event/v1"
    },
    "event_type": {
      "const": "correction_action_executed"
    },
    "event_id": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "session_id": {
      "type": "string"
    },
    "provider": {
      "type": "string"
    },
    "model_name": {
      "type": "string"
    },
    "source_snapshot": {
      "type": "object",
      "required": [
        "path",
        "snapshot_id",
        "source_snapshot_sha256",
        "schema_version",
        "correction_level",
        "c_t",
        "s_t"
      ],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^tests/fixtures/memory-stability/redacted/[A-Za-z0-9._-]+-runtime-snapshot\\.redacted\\.json$"
        },
        "snapshot_id": {
          "type": "string"
        },
        "source_snapshot_sha256": {
          "$ref": "#/$defs/Sha256"
        },
        "schema_version": {
          "const": "memory-stability-runtime-snapshot/v1"
        },
        "correction_level": {
          "enum": [
            "none",
            "light",
            "medium",
            "strong"
          ]
        },
        "c_t": {
          "$ref": "#/$defs/Score"
        },
        "s_t": {
          "$ref": "#/$defs/Score"
        }
      },
      "additionalProperties": false
    },
    "execution": {
      "type": "object",
      "required": [
        "adapter",
        "adapter_invocation_id",
        "actor_type",
        "actor_id",
        "explicit_execution",
        "automatic_by_loader",
        "loader_auto_executed",
        "model_called",
        "authoritative_store_mutated",
        "status",
        "started_at",
        "completed_at",
        "actions"
      ],
      "properties": {
        "adapter": {
          "type": "string"
        },
        "adapter_invocation_id": {
          "type": "string"
        },
        "actor_type": {
          "enum": [
            "product_adapter",
            "operator",
            "test_fixture"
          ]
        },
        "actor_id": {
          "type": "string"
        },
        "explicit_execution": {
          "const": true
        },
        "automatic_by_loader": {
          "const": false
        },
        "loader_auto_executed": {
          "const": false
        },
        "model_called": {
          "const": false
        },
        "authoritative_store_mutated": {
          "type": "boolean"
        },
        "status": {
          "enum": [
            "completed",
            "partial",
            "failed",
            "skipped"
          ]
        },
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "completed_at": {
          "type": "string",
          "format": "date-time"
        },
        "actions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/ExecutedAction"
          }
        },
        "product_provenance": {
          "$ref": "#/$defs/ProductProvenance"
        },
        "preflight": {
          "$ref": "#/$defs/ProductPreflight"
        },
        "placement_receipt": {
          "$ref": "#/$defs/PlacementReceipt"
        },
        "post_execution_runtime": {
          "$ref": "#/$defs/PostExecutionRuntime"
        },
        "idempotency_replay": {
          "$ref": "#/$defs/IdempotencyReplay"
        },
        "privacy_rollback": {
          "$ref": "#/$defs/PrivacyRollback"
        }
      },
      "additionalProperties": false
    },
    "audit": {
      "type": "object",
      "required": [
        "event_type",
        "raw_content_persisted",
        "content_policy",
        "idempotency_key",
        "notes"
      ],
      "properties": {
        "event_type": {
          "const": "correction_execution"
        },
        "raw_content_persisted": {
          "const": false
        },
        "content_policy": {
          "enum": [
            "hash_only",
            "sanitized_summary_only"
          ]
        },
        "idempotency_key": {
          "type": "string"
        },
        "notes": {
          "type": "string",
          "maxLength": 512
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "Sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "Score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "ProductProvenance": {
      "type": "object",
      "required": [
        "target_repo_path",
        "target_repo_commit",
        "adapter_version",
        "adapter_entrypoint",
        "runtime_contract_version",
        "feature_flag",
        "environment"
      ],
      "properties": {
        "target_repo_path": {
          "type": "string"
        },
        "target_repo_commit": {
          "type": "string"
        },
        "adapter_version": {
          "type": "string"
        },
        "adapter_entrypoint": {
          "type": "string"
        },
        "runtime_contract_version": {
          "type": "string"
        },
        "feature_flag": {
          "type": "string"
        },
        "environment": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "ProductPreflight": {
      "type": "object",
      "required": [
        "loader_verified",
        "profile_schema_verified",
        "snapshot_redacted",
        "model_call_blocked",
        "network_blocked",
        "raw_log_sinks_disabled",
        "rollback_available"
      ],
      "properties": {
        "loader_verified": {
          "const": true
        },
        "profile_schema_verified": {
          "const": true
        },
        "snapshot_redacted": {
          "const": true
        },
        "model_call_blocked": {
          "const": true
        },
        "network_blocked": {
          "const": true
        },
        "raw_log_sinks_disabled": {
          "const": true
        },
        "rollback_available": {
          "const": true
        }
      },
      "additionalProperties": false
    },
    "PlacementReceipt": {
      "type": "object",
      "required": [
        "placement_strategy_hash",
        "pre_layout_hash",
        "post_layout_hash",
        "anchor_position_delta",
        "injected_estimated_tokens",
        "max_budget_respected"
      ],
      "properties": {
        "placement_strategy_hash": {
          "$ref": "#/$defs/Sha256"
        },
        "pre_layout_hash": {
          "$ref": "#/$defs/Sha256"
        },
        "post_layout_hash": {
          "$ref": "#/$defs/Sha256"
        },
        "anchor_position_delta": {
          "type": "integer"
        },
        "injected_estimated_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "max_budget_respected": {
          "const": true
        }
      },
      "additionalProperties": false
    },
    "PostExecutionRuntime": {
      "type": "object",
      "required": [
        "post_execution_snapshot_sha256",
        "post_runtime_computed_at",
        "computed_by_engine_version",
        "final_c_t",
        "final_s_t"
      ],
      "properties": {
        "post_execution_snapshot_sha256": {
          "$ref": "#/$defs/Sha256"
        },
        "post_runtime_computed_at": {
          "type": "string",
          "format": "date-time"
        },
        "computed_by_engine_version": {
          "type": "string"
        },
        "final_c_t": {
          "$ref": "#/$defs/Score"
        },
        "final_s_t": {
          "$ref": "#/$defs/Score"
        }
      },
      "additionalProperties": false
    },
    "IdempotencyReplay": {
      "type": "object",
      "required": [
        "idempotency_replay_count",
        "dedupe_hit",
        "side_effect_count",
        "second_run_status"
      ],
      "properties": {
        "idempotency_replay_count": {
          "type": "integer",
          "minimum": 1
        },
        "dedupe_hit": {
          "const": true
        },
        "side_effect_count": {
          "const": 0
        },
        "second_run_status": {
          "enum": [
            "deduped",
            "skipped_duplicate"
          ]
        }
      },
      "additionalProperties": false
    },
    "PrivacyRollback": {
      "type": "object",
      "required": [
        "privacy_sink_scan_report",
        "rollback_drill_report",
        "raw_payload_scan_passed",
        "rollback_verified"
      ],
      "properties": {
        "privacy_sink_scan_report": {
          "type": "string",
          "maxLength": 512
        },
        "rollback_drill_report": {
          "type": "string",
          "maxLength": 512
        },
        "raw_payload_scan_passed": {
          "const": true
        },
        "rollback_verified": {
          "const": true
        }
      },
      "additionalProperties": false
    },
    "ExecutedAction": {
      "type": "object",
      "required": [
        "action",
        "requested_by_plan",
        "status",
        "target_memory_refs",
        "input_content_policy",
        "raw_content_persisted",
        "result"
      ],
      "properties": {
        "action": {
          "enum": [
            "continue_monitoring",
            "reanchor_key_memories_near_prompt_end",
            "raise_memory_injection_priority",
            "rewrite_working_memory_summary",
            "compress_low_value_history",
            "reload_authoritative_memory_store",
            "resolve_conflicts_and_refresh_runtime_state"
          ]
        },
        "requested_by_plan": {
          "type": "boolean"
        },
        "status": {
          "enum": [
            "completed",
            "failed",
            "skipped"
          ]
        },
        "target_memory_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/MemoryRef"
          }
        },
        "input_content_policy": {
          "enum": [
            "hash_only",
            "sanitized_summary_only",
            "none"
          ]
        },
        "raw_content_persisted": {
          "const": false
        },
        "result": {
          "type": "object",
          "required": [
            "before_c_t",
            "after_c_t",
            "summary"
          ],
          "properties": {
            "before_c_t": {
              "$ref": "#/$defs/Score"
            },
            "after_c_t": {
              "$ref": "#/$defs/Score"
            },
            "summary": {
              "type": "string",
              "maxLength": 512
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "MemoryRef": {
      "type": "object",
      "required": [
        "memory_id",
        "content_sha256"
      ],
      "properties": {
        "memory_id": {
          "type": "string"
        },
        "content_sha256": {
          "$ref": "#/$defs/Sha256"
        }
      },
      "additionalProperties": false
    }
  }
}
